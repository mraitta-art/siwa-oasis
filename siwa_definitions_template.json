    },
    "vibe": {
      "name": "Vibe & Atmosphere",
      "type": "select",
      "options": ["Rustic", "Authentic", "Spiritual", "Luxury", "Eco-friendly"],
      "searchable": true
    }
  },
  "searchPolicies": {
    "public_policy": {
      "name": "Public View Policy",
      "description": "Controls what public users can see",
      "allowedFields": ["name", "description", "stars", "cuisine", "category", "price"],
      "role": "public"
    },
    "vendor_policy": {
      "name": "Vendor View Policy",
      "description": "Controls what registered vendors can see",
      "allowedFields": ["name", "description", "stars", "cuisine", "phone", "email", "address", "price", "category"],
      "role": "vendor"
    }
  },
  "subscriptionTiers": {
    "free": { "name": "Free Tier", "features": {"maxBusinesses": 1, "canPublishMinisite": false, "maxImages": 5} },
    "basic": { "name": "Basic Tier", "features": {"maxBusinesses": 3, "canPublishMinisite": true, "maxImages": 15} },
    "premium": { "name": "Premium Tier", "features": {"maxBusinesses": 10, "canPublishMinisite": true, "maxImages": 50} }
  },
  "formTemplates": {
    "hotel": {
      "basic": [
        { "id": "f_h1", "name": "name", "label": "Hotel Name", "type": "text", "required": true, "searchable": true, "validation": {"minLength": 3, "maxLength": 100}, "permissions": {"showOnPublic": true} },
        { "id": "f_h2", "name": "description", "label": "Description", "type": "textarea", "required": true, "searchable": true, "validation": {"minLength": 10}, "permissions": {"showOnPublic": true} }
      ]
    }
  }
