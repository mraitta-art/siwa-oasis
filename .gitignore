# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# deployment bundles
/deploy_bundle
/deploy_bundle_cpanel
/siwa-cpanel-release
/siwa-cpanel-release.zip
*.zip

# sync tracking
.last-sync-hashes.json
.sync-manifest.json

# temporary logs
server_log.txt
/scratch

# auto-sync system logs (contain timestamps/commit data, not needed in repo)
sync.log
sync-git.log
*.log

# security — never commit these
secrets.json
*.key
*.pem
credentials.json
service-account.json

# database backups (can be large and contain sensitive data)
*.sql
database_backups/
*.dump
